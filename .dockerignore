# ============================================================
# .dockerignore — Exclude secrets, caches, and dev artifacts
# from the Docker build context.
#
# SECURITY: Ensures no credentials, keys, or local config
# files are ever baked into the Docker image.
# ============================================================

# ── Secrets and credentials (NEVER include in image) ─────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
.aws/
.ssh/

# ── Python caches ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────
venv/
.venv/
env/
.env_backup/

# ── Development and test files ────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.coverage
.coverage
htmlcov/
tests/
test_*.py

# ── Editor and OS files ───────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Documentation (not needed at runtime) ─────────────────────
README.md
docs/
*.md

# ── Notebooks ─────────────────────────────────────────────────
*.ipynb
.ipynb_checkpoints/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
